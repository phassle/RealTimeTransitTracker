# Trafiklab API Keys
# 1. Register an account at https://developer.trafiklab.se/
# 2. Create a new project
# 3. Subscribe to the APIs listed below and copy the keys
# 4. Copy this file to .env and fill in your keys:
#    cp .env.example .env

# GTFS Sweden 3 Realtime — used for live vehicle positions
# Subscribe at: https://developer.trafiklab.se/api/gtfs-sweden-3/console
# Tier: Bronze (free) — 30,000 requests/30 days
VITE_TRAFIKLAB_API_KEY=

# GTFS Regional Realtime
# Subscribe at: https://developer.trafiklab.se/api/gtfs-regional-realtime/console
# Tier: Bronze (free) — 30,000 requests/30 days
VITE_GTFS_REGIONAL_REALTIME_KEY=

# GTFS Regional Static — used by scripts/build-trip-mapping.js
# Subscribe at: https://developer.trafiklab.se/api/gtfs-regional-static/console
# Tier: Bronze (free) — 50 requests/30 days
VITE_GTFS_REGIONAL_STATIC_KEY=

# Alias used by build-trip-mapping.js (falls back to VITE_TRAFIKLAB_API_KEY)
GTFS_REGIONAL_API_KEY=
